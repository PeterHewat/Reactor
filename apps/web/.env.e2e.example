# ============================================================================
# Playwright smoke E2E (tasks + Clerk + Convex)
# ============================================================================
# Copy to .env.e2e.local (gitignored) or export in your shell / GitHub Actions secrets.
# Requires a Clerk *development* instance with Email + Password enabled and a
# test user that exists (or can be created) for E2E_CLERK_USER_EMAIL.
# ============================================================================

# Clerk secret key (sk_test_...) — never commit; use GitHub Actions secrets in CI
CLERK_SECRET_KEY=sk_test_your-secret-key

# Dev user email for @clerk/testing clerk.signIn({ emailAddress })
E2E_CLERK_USER_EMAIL=you+clerk_test@example.com

# Same values as apps/web/.env.local (playwright.smoke.config.ts reads these)
VITE_CONVEX_URL=https://your-project.convex.cloud
VITE_CLERK_PUBLISHABLE_KEY=pk_test_your-key-here
