{
  "name": "@repo/web",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Web app (React 19)",
  "scripts": {
    "generate:routes": "tsr generate",
    "dev": "vite --open",
    "build": "vite build",
    "preview": "vite preview --open",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "e2e": "playwright test",
