{
  "name": "reactor-monorepo",
  "version": "0.1.0",
  "description": "Multi-platform starter monorepo for Web (React 19), Mobile (React Native), and Marketing (Astro) with Convex + Clerk + Tailwind CSS",
  "author": "Peter Hewat <peter.hewat@gmail.com>",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/web",
    "apps/mobile",
    "apps/marketing",
    "convex",
    "packages/test-utils",
    "packages/ui-web",
    "packages/ui-mobile",
    "packages/ui-marketing",
    "packages/ui-shared",
    "packages/utils"
  ],
  "scripts": {
    "lint": "eslint .",
    "format": "prettier --check .",
    "format:fix": "prettier --write .",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "typecheck:refs": "tsc -b",
    "build": "tsc -b",
    "clean": "tsc -b --clean",
    "test": "bun run --filter '*' test",
    "e2e:install": "bunx playwright install chromium",
    "install:all": "bun install",
    "clean-install": "rm -rf node_modules && bun install",
    "outdated": "bun outdated",
    "update": "bun update"
  },
  "overrides": {
    "minimatch": "^10.2.4",
    "glob": "^13.0.6",
    "test-exclude": "^8.0.0"
  },
  "devDependencies": {
    "@eslint-react/eslint-plugin": "^3.0.0",
    "@eslint/js": "^10.0.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/bun": "^1.3.11",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-v8": "^4.1.1",
    "bun-types": "^1.3.11",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^17.4.0",
    "jsdom": "^29.0.1",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.57.2",
    "vite": "^8.0.2",
    "vitest": "^4.1.1"
  }
}
