# ============================================================================
# Environment Variables Template
# ============================================================================
# Created by `bun run dev:convex` when you link a project — do not copy this file to .env.local manually.
# Never commit .env.local to version control!
# ============================================================================

# ----------------------------------------------------------------------------
# Convex (Backend)
# ----------------------------------------------------------------------------
# Created when you run `bun run dev:convex` in your project (not set in the template repo)
# Find this in your Convex dashboard: https://dashboard.convex.dev
CONVEX_DEPLOYMENT=dev:your-project-name

# ----------------------------------------------------------------------------
# Clerk (Authentication) - Optional
# ----------------------------------------------------------------------------
# Get the issuer from your Clerk dashboard: https://dashboard.clerk.com
# Set CLERK_JWT_ISSUER_DOMAIN in the Convex dashboard (required; used by committed convex/auth.config.ts).
# Optional mirror below for local reference — Convex dashboard vars are authoritative.
CLERK_JWT_ISSUER_DOMAIN=https://your-clerk-domain.clerk.accounts.dev
