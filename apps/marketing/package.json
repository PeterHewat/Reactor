{
  "name": "@repo/marketing",
  "type": "module",
  "version": "0.0.1",
  "private": true,
  "description": "Astro marketing site",
  "scripts": {
    "postinstall": "ASTRO_TELEMETRY_DISABLED=1 astro sync",
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "lint": "eslint .",
    "typecheck": "astro check && tsc",
    "test": "vitest run --passWithNoTests",
    "e2e": "playwright test",
    "e2e:debug": "playwright test --headed --debug",
    "astro": "astro"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.9",
    "@astrojs/sitemap": "^3.7.2",
    "@repo/ui-marketing": "workspace:*",
    "@repo/ui-shared": "workspace:*",
    "typescript": "^6.0.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@tailwindcss/vite": "^4.3.0",
    "astro": "7.0.0-alpha.1",
    "tailwindcss": "^4.3.0"
  },
  "engines": {
    "node": ">=22.12.0"
  }
}
