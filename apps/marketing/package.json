{
  "name": "@repo/marketing",
  "type": "module",
  "version": "0.0.1",
  "private": true,
  "description": "Astro marketing site",
  "scripts": {
    "postinstall": "ASTRO_TELEMETRY_DISABLED=1 astro sync",
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "lint": "eslint .",
    "typecheck": "astro check && tsc",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "e2e": "playwright test",
    "e2e:debug": "playwright test --headed --debug",
    "astro": "astro"
  },
  "dependencies": {
    "@repo/config": "workspace:*",
    "@repo/tokens": "workspace:*",
    "@astrojs/check": "^0.9.9",
    "@astrojs/sitemap": "^3.7.3",
    "@vercel/speed-insights": "^2.0.0",
    "typescript": "~6.0.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@tailwindcss/vite": "^4.3.0",
    "astro": "^6.4.4",
    "tailwindcss": "^4.3.0",
    "vite": "^7.3.5"
  },
  "engines": {
    "node": ">=24.0.0"
  }
}
