# ============================================================================
# Web App Environment Variables
# ============================================================================
# Copy this file to .env.local and fill in your values.
# Full Clerk + Convex steps: docs/getting-started.md §2–3
# Repo URL: set by bun scripts/setup.ts from git remote
# ============================================================================

# ----------------------------------------------------------------------------
# Convex (Backend)
# ----------------------------------------------------------------------------
# After bun run dev:convex — deployment URL from Convex dashboard or CLI banner
VITE_CONVEX_URL=https://your-project.convex.cloud

# ----------------------------------------------------------------------------
# Clerk (Authentication)
# ----------------------------------------------------------------------------
# Clerk → Configure → API keys → Quick copy → framework "React" (not React Router)
VITE_CLERK_PUBLISHABLE_KEY=pk_test_your-key-here

# ----------------------------------------------------------------------------
# Repository (links in the web UI)
# ----------------------------------------------------------------------------
VITE_REPO_URL=https://github.com/YOUR_ORG/YOUR_REPO
# Optional: default branch for README links (default: main)
# VITE_REPO_DEFAULT_BRANCH=main
