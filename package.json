{
  "name": "reactor-monorepo",
  "version": "0.1.0",
  "description": "Starter monorepo for Web (React 19), Marketing (Astro), and Convex + Clerk + Tailwind CSS",
  "author": "Peter Hewat <peter.hewat@gmail.com>",
  "license": "MIT",
  "private": true,
  "packageManager": "bun@1.3.14",
  "engines": {
    "bun": ">=1.3.14",
    "node": ">=24.0.0"
  },
  "type": "module",
  "workspaces": [
    "apps/web",
    "apps/marketing",
    "convex",
    "packages/test-utils",
    "packages/ui-web",
    "packages/utils",
    "packages/tokens",
    "packages/config",
    "packages/env-core"
  ],
  "scripts": {
    "dev": "concurrently -n web,mkt -c blue,magenta \"bun run dev:web\" \"bun run dev:marketing\"",
    "dev:full": "concurrently -n web,mkt,convex -c blue,magenta,green \"bun run dev:web\" \"bun run dev:marketing\" \"bun run dev:convex\"",
    "dev:web": "bun run --filter @repo/web dev",
    "dev:marketing": "bun run --filter @repo/marketing dev",
    "dev:convex": "bunx convex dev",
    "lint": "eslint .",
    "format": "prettier --check .",
    "format:fix": "prettier --write .",
    "codegen": "bun scripts/generate.ts && bun scripts/assert-convex-generated.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "typecheck:refs": "tsc -b",
    "check": "bun run codegen && bun run lint && bun run typecheck",
    "verify": "bun run check && bun run test",
    "test": "bun run --filter '*' test",
    "test:web": "bun run --filter @repo/web test && bun run --filter @repo/ui-web test && bun run --filter @repo/utils test",
    "test:packages": "bun run --filter @repo/config test && bun run --filter @repo/env-core test && bun run --filter @repo/ui-web test && bun run --filter @repo/utils test",
    "test:integration": "bun run --filter @repo/utils test:integration",
    "e2e:install": "bunx playwright install chromium",
    "install:all": "bun install",
    "outdated": "bun outdated",
    "update": "bun update",
    "audit": "bun audit",
    "build": "tsc -b",
    "build:all": "bun run build && bun run --filter '*' build",
    "clean": "rm -rf node_modules",
    "clean:ts": "tsc -b --clean",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,mjs,cjs}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml,css,html,astro}": "prettier --write"
  },
  "overrides": {
    "ws": "^8.21.0",
    "devalue": "^5.8.1",
    "minimatch": "^10.2.5",
    "glob": "^13.0.6",
    "test-exclude": "^8.0.0",
    "brace-expansion": "^5.0.6",
    "picomatch": "^4.0.4",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@eslint-react/eslint-plugin": "^5.8.12",
    "@eslint/js": "^10.0.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/bun": "^1.3.14",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.16",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-v8": "^4.1.8",
    "bun-types": "^1.3.14",
    "concurrently": "^10.0.3",
    "convex": "^1.40.0",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "globals": "^17.6.0",
    "happy-dom": "^20.10.1",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "prettier": "^3.8.3",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.60.1",
    "vite": "^8.0.16",
    "vitest": "^4.1.8"
  }
}
