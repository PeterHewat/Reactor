# ============================================================================
# Web App Environment Variables
# ============================================================================
# Copy this file to .env.local and fill in your values.
# Quick path: bun run setup -- --repo https://github.com/YOUR_ORG/YOUR_REPO
# Never commit .env.local to version control!
# ============================================================================

# ----------------------------------------------------------------------------
# Convex (Backend)
# ----------------------------------------------------------------------------
# Set after you run `bun run dev:convex` and link your own Convex project
# Use requireWebEnv() in main.tsx when enabling Convex — fails fast if missing (see apps/web/src/env.ts)
VITE_CONVEX_URL=https://your-project.convex.cloud

# ----------------------------------------------------------------------------
# Clerk (Authentication) - Optional
# ----------------------------------------------------------------------------
# Your Clerk publishable key (starts with pk_test_ or pk_live_)
# Get this from your Clerk dashboard: https://dashboard.clerk.com
VITE_CLERK_PUBLISHABLE_KEY=pk_test_your-key-here

# ----------------------------------------------------------------------------
# Repository (links in the web UI)
# ----------------------------------------------------------------------------
# Public GitHub URL for this repo (README links in the web UI; not the upstream Reactor template)
VITE_REPO_URL=https://github.com/YOUR_ORG/YOUR_REPO
# Optional: default branch for README links (default: main)
# VITE_REPO_DEFAULT_BRANCH=main
