# ============================================================================
# Web App Environment Variables
# ============================================================================
# Copy to .env.local and fill in your values.
# Setup: docs/getting-started.md
# ============================================================================

# Convex — URL from `bun run dev:convex` or the Convex dashboard
VITE_CONVEX_URL=https://your-project.convex.cloud

# Clerk — Configure → API keys → React → publishable key
VITE_CLERK_PUBLISHABLE_KEY=pk_test_your-key-here

# Playwright E2E — secret key (never exposed to the Vite client)
CLERK_SECRET_KEY=sk_test_your-secret-key

# Playwright E2E — dev user with Email + Password (see Clerk testing docs)
E2E_CLERK_USER_EMAIL=you+clerk_test@example.com
