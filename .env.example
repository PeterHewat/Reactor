# ============================================================================
# Environment Variables Template
# ============================================================================
# Copy this file to .env.local and fill in your values.
# Never commit .env.local to version control!
# ============================================================================

# ----------------------------------------------------------------------------
# Convex (Backend)
# ----------------------------------------------------------------------------
# Created when you run `bunx convex dev` in your project (not set in the template repo)
# Find this in your Convex dashboard: https://dashboard.convex.dev
CONVEX_DEPLOYMENT=dev:your-project-name

# ----------------------------------------------------------------------------
# Clerk (Authentication) - Optional
# ----------------------------------------------------------------------------
# Get these from your Clerk dashboard: https://dashboard.clerk.com
# Set CLERK_JWT_ISSUER_DOMAIN in the Convex dashboard (not only here) when using Clerk.
# Copy convex/auth.config.ts.example → convex/auth.config.ts after enabling Clerk.
CLERK_JWT_ISSUER_DOMAIN=https://your-clerk-domain.clerk.accounts.dev
