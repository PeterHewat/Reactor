/**
 * Clerk + Convex auth configuration.
 *
 * Setup:
 * 1. Copy this file to `convex/auth.config.ts`
 * 2. Set `CLERK_JWT_ISSUER_DOMAIN` in the Convex dashboard (Settings → Environment Variables)
 *    to your Clerk JWT issuer, e.g. https://your-app.clerk.accounts.dev
 *
 * @see https://docs.convex.dev/auth/clerk
 */
export default {
  providers: [
    {
      domain: process.env.CLERK_JWT_ISSUER_DOMAIN!,
      applicationID: "convex",
    },
  ],
};
