{
  "name": "reactor-monorepo",
  "version": "0.1.0",
  "description": "Starter monorepo for Web (React 19), Marketing (Astro), and Convex + Clerk + Tailwind CSS",
  "author": "Peter Hewat <peter.hewat@gmail.com>",
  "license": "MIT",
  "private": true,
  "packageManager": "bun@1.3.13",
  "engines": {
    "bun": ">=1.3.13",
    "node": ">=22.12.0"
  },
  "type": "module",
  "workspaces": [
    "apps/web",
    "apps/marketing",
    "convex",
    "packages/test-utils",
    "packages/ui-web",
    "packages/utils"
  ],
  "scripts": {
    "dev:web": "bun run --filter @repo/web dev",
    "dev:marketing": "bun run --filter @repo/marketing dev",
    "lint": "eslint .",
    "format": "prettier --check .",
    "format:fix": "prettier --write .",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "typecheck:refs": "tsc -b",
    "build": "tsc -b",
    "clean": "tsc -b --clean",
    "test": "bun run --filter '@repo/web' --filter '@repo/marketing' --filter '@repo/convex' --filter '@repo/ui-web' --filter '@repo/utils' test",
    "e2e:install": "bunx playwright install chromium",
    "install:all": "bun install",
    "clean-install": "rm -rf node_modules && bun install",
    "outdated": "bun outdated",
    "update": "bun update",
    "audit": "bun audit",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,mjs,cjs}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml,css,html,astro}": "prettier --write"
  },
  "overrides": {
    "ws": "^8.21.0",
    "devalue": "^5.8.1",
    "minimatch": "^10.2.5",
    "glob": "^13.0.6",
    "test-exclude": "^8.0.0",
    "brace-expansion": "^5.0.6",
    "picomatch": "^4.0.4",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@eslint-react/eslint-plugin": "^5.8.4",
    "@eslint/js": "^10.0.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/bun": "^1.3.14",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-v8": "^4.1.7",
    "bun-types": "^1.3.14",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^17.6.0",
    "happy-dom": "^20.9.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.5",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.59.4",
    "vite": "^8.0.14",
    "vitest": "^4.1.7"
  }
}
